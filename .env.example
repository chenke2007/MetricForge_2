# MetricForge — AI 智能问数与报表 SQL 开发平台

## 环境变量（必填）
ORACLE_PASSWORD=your_oracle_readonly_password
METRICFORGE_ENCRYPTION_KEY=your_32_byte_base64_encryption_key

## 环境变量（可选，有默认值）
# METRICFORGE_DB_URL=sqlite:///./data/metricforge.db
# METRICFORGE_CONFIG=./config/app_config.yaml
# METRICFORGE_DEBUG=true
# METRICFORGE_LOG_LEVEL=INFO
